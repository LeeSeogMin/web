%% 그림 1.5 DOM 트리 예시
%% 제1장 1.3절에서 사용

flowchart TB
    subgraph HTML["HTML 소스 코드"]
        direction TB
        CODE["&lt;html&gt;<br/>  &lt;head&gt;<br/>    &lt;title&gt;제목&lt;/title&gt;<br/>  &lt;/head&gt;<br/>  &lt;body&gt;<br/>    &lt;div id='container'&gt;<br/>      &lt;h1&gt;환영합니다&lt;/h1&gt;<br/>      &lt;p class='intro'&gt;본문입니다&lt;/p&gt;<br/>    &lt;/div&gt;<br/>  &lt;/body&gt;<br/>&lt;/html&gt;"]
    end

    subgraph DOM["DOM 트리"]
        direction TB
        A[Document]
        B[html]
        C[head]
        D[body]
        E[title]
        F["div<br/>#container"]
        G["'제목'<br/>(텍스트 노드)"]
        H[h1]
        I["p<br/>.intro"]
        J["'환영합니다'<br/>(텍스트 노드)"]
        K["'본문입니다'<br/>(텍스트 노드)"]

        A --> B
        B --> C
        B --> D
        C --> E
        E --> G
        D --> F
        F --> H
        F --> I
        H --> J
        I --> K
    end

    HTML -.->|"파싱"| DOM

    style A fill:#ffcdd2
    style B fill:#f8bbd9
    style C fill:#e1bee7
    style D fill:#e1bee7
    style E fill:#c5cae9
    style F fill:#c5cae9
    style H fill:#b3e5fc
    style I fill:#b3e5fc
