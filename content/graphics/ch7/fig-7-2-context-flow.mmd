%%{init: {'theme': 'base', 'themeVariables': { 'primaryColor': '#e3f2fd', 'primaryTextColor': '#1565c0', 'primaryBorderColor': '#1976d2', 'lineColor': '#1976d2'}}}%%
flowchart TB
    subgraph Provider["ThemeContext.Provider"]
        direction TB
        Value["value = { theme, toggleTheme }"]

        subgraph App["App"]
            Header["Header<br/>useContext(ThemeContext)"]
            Main["Main"]
            Footer["Footer<br/>useContext(ThemeContext)"]

            subgraph Nested["중첩 컴포넌트"]
                Button["Button<br/>useContext(ThemeContext)"]
            end
        end
    end

    Value -.->|"theme"| Header
    Value -.->|"theme"| Footer
    Value -.->|"theme"| Button

    Note["✓ Props 전달 없이 직접 접근<br/>✓ Provider 하위 모든 컴포넌트에서 사용 가능"]

    style Provider fill:#e3f2fd,stroke:#1976d2
    style Value fill:#fff3e0,stroke:#ff9800
    style Note fill:#e8f5e9,stroke:#4caf50
