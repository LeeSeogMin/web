%% 그림 3.1: HTML5 문서 기본 구조

flowchart TB
    subgraph HTML["&lt;html&gt;"]
        subgraph HEAD["&lt;head&gt;"]
            META["&lt;meta charset&gt;"]
            TITLE["&lt;title&gt;"]
            LINK["&lt;link&gt; CSS"]
        end

        subgraph BODY["&lt;body&gt;"]
            HEADER["&lt;header&gt;<br/>로고, 내비게이션"]
            NAV["&lt;nav&gt;<br/>메뉴 링크"]
            MAIN["&lt;main&gt;<br/>주요 콘텐츠"]
            ASIDE["&lt;aside&gt;<br/>사이드바"]
            FOOTER["&lt;footer&gt;<br/>저작권, 연락처"]
        end
    end

    style HTML fill:#e1f5fe
    style HEAD fill:#fff3e0
    style BODY fill:#e8f5e9
    style MAIN fill:#c8e6c9
