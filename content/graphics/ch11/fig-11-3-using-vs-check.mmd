%%{init: {'theme': 'base', 'themeVariables': { 'primaryColor': '#3ECF8E'}}}%%
graph LR
    subgraph "USING 조건"
        A[기존 행] --> B{조건 검사}
        B -->|true| C[행 반환]
        B -->|false| D[행 숨김]
    end

    subgraph "WITH CHECK 조건"
        E[새 데이터] --> F{조건 검사}
        F -->|true| G[저장 허용]
        F -->|false| H[에러 발생]
    end

    I[SELECT] --> A
    J[DELETE] --> A
    K[INSERT] --> E
    L[UPDATE] --> A
    L --> E

    style C fill:#3ECF8E,color:#fff
    style G fill:#3ECF8E,color:#fff
    style D fill:#fbbf24,color:#000
    style H fill:#ef4444,color:#fff
